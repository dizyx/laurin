# Laurin Configuration
# Copy to .env and fill in values for local development
# On the Laurin VPS, these live in /etc/laurin/infisical.env

# Server
PORT=3600
HOST=0.0.0.0
NODE_ENV=development

# Database
LAURIN_DATABASE_URL=postgresql://laurin:password@localhost:5432/laurin

# Infisical Cloud
INFISICAL_CLIENT_ID=your-client-id
INFISICAL_CLIENT_SECRET=your-client-secret
INFISICAL_PROJECT_ID=your-project-id
INFISICAL_ENVIRONMENT=prod
INFISICAL_API_URL=https://app.infisical.com

# Secret cache TTL (milliseconds)
SECRET_CACHE_TTL_MS=60000

# Nockerl Gateway (for inbox notifications)
GATEWAY_URL=http://100.112.204.112:3500
